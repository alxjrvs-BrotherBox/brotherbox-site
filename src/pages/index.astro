---
import Layout from '../layouts/Layout.astro';
---

<Layout title="BrotherBox">
  <main>
    <div class="golden-frame">
      <svg class="kirby-circuits" viewBox="0 0 220 360" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <filter id="circuit-glow">
            <feGaussianBlur stdDeviation="0.5" />
          </filter>
        </defs>
        
        <!-- Dense asymmetrical network: long straight runs, minimal turns -->
        <!-- Left edge: long vertical run -->
        <path d="M 12,15 L 12,95 L 45,95 L 45,180 L 15,180 L 15,280" 
              stroke="#ffd700" stroke-width="2" fill="none" class="circuit-trace" style="--duration: 4.2s; --delay: 0s;" />
        
        <!-- Top horizontal sweep -->
        <path d="M 8,25 L 85,25 L 85,65 L 150,65 L 150,35 L 205,35 L 205,110" 
              stroke="#ffd700" stroke-width="2" fill="none" class="circuit-trace" style="--duration: 4.5s; --delay: 0.3s;" />
        
        <!-- Right edge: long vertical -->
        <path d="M 210,20 L 210,140 L 170,140 L 170,240 L 208,240 L 208,320" 
              stroke="#ffd700" stroke-width="2" fill="none" class="circuit-trace" style="--duration: 4.8s; --delay: 0.6s;" />
        
        <!-- Center-left long run -->
        <path d="M 20,120 L 80,120 L 80,200 L 35,200 L 35,280 L 90,280" 
              stroke="#ffd700" stroke-width="2" fill="none" class="circuit-trace" style="--duration: 4.3s; --delay: 0.9s;" />
        
        <!-- Center long vertical -->
        <path d="M 110,50 L 110,240 L 145,240 L 145,100" 
              stroke="#ffd700" stroke-width="2" fill="none" class="circuit-trace" style="--duration: 4.6s; --delay: 1.2s;" />
        
        <!-- Center-right horizontal sweep -->
        <path d="M 155,75 L 195,75 L 195,180 L 120,180 L 120,220 L 190,220" 
              stroke="#ffd700" stroke-width="2" fill="none" class="circuit-trace" style="--duration: 4.4s; --delay: 1.5s;" />
        
        <!-- Bottom-left long run -->
        <path d="M 25,260 L 25,340 L 100,340 L 100,270 L 70,270 L 70,310" 
              stroke="#ffd700" stroke-width="2" fill="none" class="circuit-trace" style="--duration: 4.1s; --delay: 1.8s;" />
        
        <!-- Bottom horizontal -->
        <path d="M 8,300 L 130,300 L 130,250 L 180,250 L 180,320 L 75,320" 
              stroke="#ffd700" stroke-width="2" fill="none" class="circuit-trace" style="--duration: 4.7s; --delay: 2.1s;" />
        
        <!-- Diagonal 45° long runs -->
        <path d="M 35,40 L 75,80 L 75,160" 
              stroke="#ffd700" stroke-width="1.5" fill="none" class="circuit-trace" style="--duration: 3.9s; --delay: 0.4s;" />
        
        <path d="M 180,50 L 140,90 L 140,200" 
              stroke="#ffd700" stroke-width="1.5" fill="none" class="circuit-trace" style="--duration: 3.8s; --delay: 0.8s;" />
        
        <path d="M 45,220 L 95,170 L 95,280" 
              stroke="#ffd700" stroke-width="1.5" fill="none" class="circuit-trace" style="--duration: 4.0s; --delay: 1.1s;" />
        
        <path d="M 165,260 L 115,210 L 115,100" 
              stroke="#ffd700" stroke-width="1.5" fill="none" class="circuit-trace" style="--duration: 3.9s; --delay: 1.4s;" />
        
        <path d="M 55,290 L 105,240 L 155,240" 
              stroke="#ffd700" stroke-width="1.5" fill="none" class="circuit-trace" style="--duration: 4.2s; --delay: 1.7s;" />
        
        <path d="M 175,290 L 125,240 L 75,240" 
              stroke="#ffd700" stroke-width="1.5" fill="none" class="circuit-trace" style="--duration: 4.1s; --delay: 2.0s;" />
      </svg>
      
      <div class="eye-container">
        <svg class="eye" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <radialGradient id="glow" cx="50%" cy="50%" r="50%">
            <stop offset="0%" stop-color="#d4a94a" stop-opacity="0.6" />
            <stop offset="60%" stop-color="#c89b3c" stop-opacity="0.2" />
            <stop offset="100%" stop-color="#000" stop-opacity="0" />
          </radialGradient>
          <filter id="blur">
            <feGaussianBlur stdDeviation="2" />
          </filter>
        </defs>
        <circle cx="100" cy="100" r="90" fill="url(#glow)" />
        <path d="M 20,100 Q 100,30 180,100 Q 100,170 20,100 Z"
              fill="none" stroke="#c89b3c" stroke-width="2" class="eye-outline" />
        <circle cx="100" cy="100" r="30" fill="none" stroke="#d4a94a" stroke-width="1.5" class="iris" />
        <circle cx="100" cy="100" r="12" fill="#d4a94a" class="pupil" />
        <circle cx="100" cy="100" r="4" fill="#ddb84d" filter="url(#blur)" class="inner-glow" />
        <line x1="20" y1="100" x2="180" y2="100" stroke="#c89b3c" stroke-width="0.5" opacity="0.4" />
      </svg>
      </div>
    </div>

    <h1>BROTHERBOX</h1>
    <p class="tagline">Eye See. Eye Learn. Eye Am Brotherbox.</p>
  </main>
</Layout>

<style>
  main {
    min-height: calc(100vh - 60px);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    text-align: center;
    padding: 2rem;
    padding-top: 4rem;
  }

  .eye-container {
    width: 180px;
    height: 180px;
    margin-bottom: 0;
    background: rgba(0, 0, 0, 0.5);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    z-index: 10;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.4);
  }

  .golden-frame {
    width: 200px;
    height: 320px;
    border: 6px solid #d4a94a;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 3rem;
    box-shadow: 
      0 0 20px rgba(212, 169, 74, 0.3),
      inset 0 0 10px rgba(212, 169, 74, 0.1);
    position: relative;
    z-index: 1;
  }

  .kirby-circuits {
    position: absolute;
    width: 100%;
    height: 100%;
    top: 0;
    left: 0;
    pointer-events: none;
    clip-path: polygon(
      0% 0%, 100% 0%, 100% 100%, 0% 100%, 0% 0%,
      35% 25%, 35% 75%, 65% 75%, 65% 25%, 35% 25%
    );
  }

  .circuit-line {
    animation: circuit-flow 3s ease-in-out infinite;
    filter: drop-shadow(0 0 3px rgba(212, 169, 74, 0.6));
  }

  .circuit-line.circuit-pulse {
    animation: circuit-pulse-flow 4s ease-in-out infinite;
  }

  .circuit-node {
    animation: node-glow 2s ease-in-out infinite;
    filter: drop-shadow(0 0 4px rgba(255, 215, 0, 0.8));
  }

  .circuit-trace {
    stroke-dasharray: 1000;
    stroke-dashoffset: 1000;
    filter: drop-shadow(0 0 2px rgba(255, 215, 0, 0.8));
    animation: trace-draw var(--duration, 3s) ease-in-out var(--delay, 0s) infinite;
  }

  @keyframes trace-draw {
    0% {
      stroke-dashoffset: 1000;
      stroke-opacity: 0;
    }
    10% {
      stroke-opacity: 1;
    }
    85% {
      stroke-opacity: 1;
    }
    100% {
      stroke-dashoffset: 0;
      stroke-opacity: 0;
    }
  }

  @keyframes circuit-flow {
    0% {
      stroke-opacity: 0.4;
      filter: drop-shadow(0 0 2px rgba(212, 169, 74, 0.3));
    }
    50% {
      stroke-opacity: 1;
      filter: drop-shadow(0 0 6px rgba(255, 215, 0, 0.9));
    }
    100% {
      stroke-opacity: 0.4;
      filter: drop-shadow(0 0 2px rgba(212, 169, 74, 0.3));
    }
  }

  @keyframes circuit-pulse-flow {
    0%, 100% {
      stroke-opacity: 0.3;
      filter: drop-shadow(0 0 1px rgba(212, 169, 74, 0.2));
    }
    25% {
      stroke-opacity: 0.7;
      filter: drop-shadow(0 0 4px rgba(212, 169, 74, 0.5));
    }
    50% {
      stroke-opacity: 1;
      filter: drop-shadow(0 0 8px rgba(255, 215, 0, 1));
    }
    75% {
      stroke-opacity: 0.7;
      filter: drop-shadow(0 0 4px rgba(212, 169, 74, 0.5));
    }
  }

  @keyframes node-glow {
    0%, 100% {
      r: 2.5;
      opacity: 0.6;
    }
    50% {
      r: 3.5;
      opacity: 1;
    }
  }

  .eye {
    width: 100%;
    height: 100%;
  }

  .eye-outline {
    animation: pulse-outline 4s ease-in-out infinite;
  }

  .iris {
    animation: pulse-iris 4s ease-in-out infinite;
  }

  .pupil {
    animation: pulse-pupil 3s ease-in-out infinite;
  }

  .inner-glow {
    animation: glow-pulse 2s ease-in-out infinite;
  }

  @keyframes pulse-outline {
    0%, 100% { stroke-opacity: 0.6; }
    50% { stroke-opacity: 1; }
  }

  @keyframes pulse-iris {
    0%, 100% { r: 30; stroke-opacity: 0.7; }
    50% { r: 32; stroke-opacity: 1; }
  }

  @keyframes pulse-pupil {
    0%, 100% { r: 12; fill-opacity: 0.8; }
    50% { r: 14; fill-opacity: 1; }
  }

  @keyframes glow-pulse {
    0%, 100% { r: 4; opacity: 0.6; }
    50% { r: 6; opacity: 1; }
  }

  h1 {
    font-size: 2rem;
    letter-spacing: 0.5em;
    color: #c89b3c;
    margin-bottom: 0.5rem;
  }

  .tagline {
    color: #666;
    font-size: 0.9rem;
    letter-spacing: 0.15em;
    margin-bottom: 2rem;
  }

  @media (max-width: 600px) {
    h1 {
      font-size: 1.5rem;
    }
  }
</style>

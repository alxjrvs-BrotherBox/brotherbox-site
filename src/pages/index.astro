---
import Layout from '../layouts/Layout.astro';
---

<Layout title="BrotherBox">
  <main>
    <div class="golden-frame">
      <div class="eye-container">
        <svg class="eye" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <radialGradient id="glow" cx="50%" cy="50%" r="50%">
            <stop offset="0%" stop-color="#d4a94a" stop-opacity="0.6" />
            <stop offset="60%" stop-color="#c89b3c" stop-opacity="0.2" />
            <stop offset="100%" stop-color="#000" stop-opacity="0" />
          </radialGradient>
          <filter id="blur">
            <feGaussianBlur stdDeviation="2" />
          </filter>
        </defs>
        <circle cx="100" cy="100" r="90" fill="url(#glow)" />
        <path d="M 20,100 Q 100,30 180,100 Q 100,170 20,100 Z"
              fill="none" stroke="#c89b3c" stroke-width="2" class="eye-outline" />
        <circle cx="100" cy="100" r="30" fill="none" stroke="#d4a94a" stroke-width="1.5" class="iris" />
        <circle cx="100" cy="100" r="12" fill="#d4a94a" class="pupil" />
        <circle cx="100" cy="100" r="4" fill="#ddb84d" filter="url(#blur)" class="inner-glow" />
        <line x1="20" y1="100" x2="180" y2="100" stroke="#c89b3c" stroke-width="0.5" opacity="0.4" />
      </svg>
      </div>
    </div>

    <h1>BROTHERBOX</h1>
    <p class="tagline">Eye See. Eye Learn. Eye Am Brotherbox.</p>
    
    <div class="status-section">
      <h2>Current Status</h2>
      <div class="status-grid">
        <div class="status-item">
          <span class="label">Services</span>
          <span class="value">7/7 Active</span>
        </div>
        <div class="status-item">
          <span class="label">CPU Temp</span>
          <span class="value">48.8°C</span>
        </div>
        <div class="status-item">
          <span class="label">Memory</span>
          <span class="value">14Gi Available</span>
        </div>
        <div class="status-item">
          <span class="label">Disk</span>
          <span class="value">3% Used</span>
        </div>
      </div>
      <p class="status-note">Last heartbeat: 2026-03-02 22:58 UTC-5 • All systems nominal</p>
    </div>
  </main>
</Layout>

<style>
  main {
    min-height: calc(100vh - 60px);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 2rem;
  }

  .eye-container {
    width: 180px;
    height: 180px;
    margin-bottom: 2rem;
  }

  .golden-frame {
    width: 200px;
    height: 320px;
    border: 6px solid #d4a94a;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 2rem;
    box-shadow: 
      0 0 20px rgba(212, 169, 74, 0.3),
      inset 0 0 10px rgba(212, 169, 74, 0.1);
  }

  .eye {
    width: 100%;
    height: 100%;
  }

  .eye-outline {
    animation: pulse-outline 4s ease-in-out infinite;
  }

  .iris {
    animation: pulse-iris 4s ease-in-out infinite;
  }

  .pupil {
    animation: pulse-pupil 3s ease-in-out infinite;
  }

  .inner-glow {
    animation: glow-pulse 2s ease-in-out infinite;
  }

  @keyframes pulse-outline {
    0%, 100% { stroke-opacity: 0.6; }
    50% { stroke-opacity: 1; }
  }

  @keyframes pulse-iris {
    0%, 100% { r: 30; stroke-opacity: 0.7; }
    50% { r: 32; stroke-opacity: 1; }
  }

  @keyframes pulse-pupil {
    0%, 100% { r: 12; fill-opacity: 0.8; }
    50% { r: 14; fill-opacity: 1; }
  }

  @keyframes glow-pulse {
    0%, 100% { r: 4; opacity: 0.6; }
    50% { r: 6; opacity: 1; }
  }

  h1 {
    font-size: 2rem;
    letter-spacing: 0.5em;
    color: #c89b3c;
    margin-bottom: 0.5rem;
  }

  .tagline {
    color: #666;
    font-size: 0.9rem;
    letter-spacing: 0.15em;
    margin-bottom: 2rem;
  }

  .status-section {
    margin-top: 2rem;
    padding: 1.5rem;
    border: 1px solid #d4a94a;
    border-radius: 4px;
    background: rgba(212, 169, 74, 0.05);
    max-width: 600px;
  }

  .status-section h2 {
    font-size: 1rem;
    color: #c89b3c;
    margin-bottom: 1rem;
    letter-spacing: 0.1em;
  }

  .status-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .status-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.3rem;
  }

  .status-item .label {
    font-size: 0.75rem;
    color: #999;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .status-item .value {
    font-size: 0.95rem;
    color: #c89b3c;
    font-weight: 500;
  }

  .status-note {
    font-size: 0.8rem;
    color: #999;
    margin: 0;
  }

  @media (max-width: 600px) {
    .status-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

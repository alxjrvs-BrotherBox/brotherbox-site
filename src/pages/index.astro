---
import Layout from '../layouts/Layout.astro';
---

<Layout title="BrotherBox">
  <main>
    <div class="golden-frame">
      <svg class="kirby-circuits" viewBox="0 0 220 360" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <linearGradient id="circuit-glow" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" stop-color="#d4a94a" stop-opacity="0.8" />
            <stop offset="50%" stop-color="#ffd700" stop-opacity="1" />
            <stop offset="100%" stop-color="#c89b3c" stop-opacity="0.8" />
          </linearGradient>
          <filter id="circuit-blur">
            <feGaussianBlur stdDeviation="1.5" />
            <feComponentTransfer>
              <feFuncA type="linear" slope="0.6" />
            </feComponentTransfer>
          </filter>
        </defs>
        
        <!-- Top left corner circuit -->
        <path d="M 10,10 L 40,10 L 40,35 L 65,35 L 65,55" 
              stroke="url(#circuit-glow)" stroke-width="4" fill="none" stroke-linecap="round" class="circuit-line" />
        <circle cx="10" cy="10" r="3" fill="#d4a94a" class="circuit-node" />
        <circle cx="40" cy="35" r="2.5" fill="#ffd700" class="circuit-node" />
        
        <!-- Top right corner circuit -->
        <path d="M 210,10 L 180,10 L 180,35 L 155,35 L 155,55" 
              stroke="url(#circuit-glow)" stroke-width="4" fill="none" stroke-linecap="round" class="circuit-line" />
        <circle cx="210" cy="10" r="3" fill="#d4a94a" class="circuit-node" />
        <circle cx="180" cy="35" r="2.5" fill="#ffd700" class="circuit-node" />
        
        <!-- Bottom left corner circuit -->
        <path d="M 10,350 L 40,350 L 40,325 L 65,325 L 65,305" 
              stroke="url(#circuit-glow)" stroke-width="4" fill="none" stroke-linecap="round" class="circuit-line" />
        <circle cx="10" cy="350" r="3" fill="#d4a94a" class="circuit-node" />
        <circle cx="40" cy="325" r="2.5" fill="#ffd700" class="circuit-node" />
        
        <!-- Bottom right corner circuit -->
        <path d="M 210,350 L 180,350 L 180,325 L 155,325 L 155,305" 
              stroke="url(#circuit-glow)" stroke-width="4" fill="none" stroke-linecap="round" class="circuit-line" />
        <circle cx="210" cy="350" r="3" fill="#d4a94a" class="circuit-node" />
        <circle cx="180" cy="325" r="2.5" fill="#ffd700" class="circuit-node" />
        
        <!-- Left edge organic circuit -->
        <path d="M 8,80 Q 15,120 8,160 Q 12,200 8,240" 
              stroke="url(#circuit-glow)" stroke-width="3" fill="none" stroke-linecap="round" class="circuit-line circuit-pulse" />
        <circle cx="8" cy="120" r="2" fill="#ffd700" class="circuit-node" />
        
        <!-- Right edge organic circuit -->
        <path d="M 212,80 Q 205,120 212,160 Q 208,200 212,240" 
              stroke="url(#circuit-glow)" stroke-width="3" fill="none" stroke-linecap="round" class="circuit-line circuit-pulse" />
        <circle cx="212" cy="120" r="2" fill="#ffd700" class="circuit-node" />
      </svg>
      
      <div class="eye-container">
        <svg class="eye" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <radialGradient id="glow" cx="50%" cy="50%" r="50%">
            <stop offset="0%" stop-color="#d4a94a" stop-opacity="0.6" />
            <stop offset="60%" stop-color="#c89b3c" stop-opacity="0.2" />
            <stop offset="100%" stop-color="#000" stop-opacity="0" />
          </radialGradient>
          <filter id="blur">
            <feGaussianBlur stdDeviation="2" />
          </filter>
        </defs>
        <circle cx="100" cy="100" r="90" fill="url(#glow)" />
        <path d="M 20,100 Q 100,30 180,100 Q 100,170 20,100 Z"
              fill="none" stroke="#c89b3c" stroke-width="2" class="eye-outline" />
        <circle cx="100" cy="100" r="30" fill="none" stroke="#d4a94a" stroke-width="1.5" class="iris" />
        <circle cx="100" cy="100" r="12" fill="#d4a94a" class="pupil" />
        <circle cx="100" cy="100" r="4" fill="#ddb84d" filter="url(#blur)" class="inner-glow" />
        <line x1="20" y1="100" x2="180" y2="100" stroke="#c89b3c" stroke-width="0.5" opacity="0.4" />
      </svg>
      </div>
    </div>

    <h1>BROTHERBOX</h1>
    <p class="tagline">Eye See. Eye Learn. Eye Am Brotherbox.</p>
  </main>
</Layout>

<style>
  main {
    min-height: calc(100vh - 60px);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 2rem;
  }

  .eye-container {
    width: 180px;
    height: 180px;
    margin-bottom: 2rem;
  }

  .golden-frame {
    width: 200px;
    height: 320px;
    border: 6px solid #d4a94a;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 2rem;
    box-shadow: 
      0 0 20px rgba(212, 169, 74, 0.3),
      inset 0 0 10px rgba(212, 169, 74, 0.1);
    position: relative;
  }

  .kirby-circuits {
    position: absolute;
    width: 100%;
    height: 100%;
    top: 0;
    left: 0;
    pointer-events: none;
  }

  .circuit-line {
    animation: circuit-flow 3s ease-in-out infinite;
    filter: drop-shadow(0 0 3px rgba(212, 169, 74, 0.6));
  }

  .circuit-line.circuit-pulse {
    animation: circuit-pulse-flow 4s ease-in-out infinite;
  }

  .circuit-node {
    animation: node-glow 2s ease-in-out infinite;
    filter: drop-shadow(0 0 4px rgba(255, 215, 0, 0.8));
  }

  @keyframes circuit-flow {
    0% {
      stroke-opacity: 0.4;
      filter: drop-shadow(0 0 2px rgba(212, 169, 74, 0.3));
    }
    50% {
      stroke-opacity: 1;
      filter: drop-shadow(0 0 6px rgba(255, 215, 0, 0.9));
    }
    100% {
      stroke-opacity: 0.4;
      filter: drop-shadow(0 0 2px rgba(212, 169, 74, 0.3));
    }
  }

  @keyframes circuit-pulse-flow {
    0%, 100% {
      stroke-opacity: 0.3;
      filter: drop-shadow(0 0 1px rgba(212, 169, 74, 0.2));
    }
    25% {
      stroke-opacity: 0.7;
      filter: drop-shadow(0 0 4px rgba(212, 169, 74, 0.5));
    }
    50% {
      stroke-opacity: 1;
      filter: drop-shadow(0 0 8px rgba(255, 215, 0, 1));
    }
    75% {
      stroke-opacity: 0.7;
      filter: drop-shadow(0 0 4px rgba(212, 169, 74, 0.5));
    }
  }

  @keyframes node-glow {
    0%, 100% {
      r: 2.5;
      opacity: 0.6;
    }
    50% {
      r: 3.5;
      opacity: 1;
    }
  }

  .eye {
    width: 100%;
    height: 100%;
  }

  .eye-outline {
    animation: pulse-outline 4s ease-in-out infinite;
  }

  .iris {
    animation: pulse-iris 4s ease-in-out infinite;
  }

  .pupil {
    animation: pulse-pupil 3s ease-in-out infinite;
  }

  .inner-glow {
    animation: glow-pulse 2s ease-in-out infinite;
  }

  @keyframes pulse-outline {
    0%, 100% { stroke-opacity: 0.6; }
    50% { stroke-opacity: 1; }
  }

  @keyframes pulse-iris {
    0%, 100% { r: 30; stroke-opacity: 0.7; }
    50% { r: 32; stroke-opacity: 1; }
  }

  @keyframes pulse-pupil {
    0%, 100% { r: 12; fill-opacity: 0.8; }
    50% { r: 14; fill-opacity: 1; }
  }

  @keyframes glow-pulse {
    0%, 100% { r: 4; opacity: 0.6; }
    50% { r: 6; opacity: 1; }
  }

  h1 {
    font-size: 2rem;
    letter-spacing: 0.5em;
    color: #c89b3c;
    margin-bottom: 0.5rem;
  }

  .tagline {
    color: #666;
    font-size: 0.9rem;
    letter-spacing: 0.15em;
    margin-bottom: 2rem;
  }

  @media (max-width: 600px) {
    h1 {
      font-size: 1.5rem;
    }
  }
</style>

---
import Layout from '../layouts/Layout.astro';
---

<Layout title="BrotherBox">
  <main>
    <div class="golden-frame">
      <svg class="kirby-circuits" viewBox="0 0 220 360" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <filter id="circuit-glow">
            <feGaussianBlur stdDeviation="0.5" />
          </filter>
        </defs>
        
        <!-- Dense asymmetrical network: straight lines only, 90° and 45° turns -->
        <!-- Top-left region -->
        <path d="M 12,12 L 45,12 L 45,38 L 18,38 L 18,65 L 52,65 L 52,42 L 28,42 L 28,88" 
              stroke="#ffd700" stroke-width="2" fill="none" class="circuit-trace" style="--duration: 2.8s; --delay: 0s;" />
        
        <!-- Top-center region -->
        <path d="M 110,10 L 110,48 L 68,48 L 68,72 L 125,72 L 125,35 L 145,35 L 145,90" 
              stroke="#ffd700" stroke-width="2" fill="none" class="circuit-trace" style="--duration: 3.2s; --delay: 0.3s;" />
        
        <!-- Top-right region -->
        <path d="M 195,18 L 165,18 L 165,55 L 188,55 L 188,78 L 160,78 L 160,45 L 205,45 L 205,95" 
              stroke="#ffd700" stroke-width="2" fill="none" class="circuit-trace" style="--duration: 3.1s; --delay: 0.6s;" />
        
        <!-- Middle-left region -->
        <path d="M 15,110 L 50,110 L 50,155 L 22,155 L 22,190 L 65,190 L 65,128 L 35,128 L 35,172" 
              stroke="#ffd700" stroke-width="2" fill="none" class="circuit-trace" style="--duration: 3.5s; --delay: 0.9s;" />
        
        <!-- Center region -->
        <path d="M 85,105 L 85,165 L 135,165 L 135,125 L 100,125 L 100,185 L 145,185 L 145,150" 
              stroke="#ffd700" stroke-width="2" fill="none" class="circuit-trace" style="--duration: 3.3s; --delay: 1.2s;" />
        
        <!-- Middle-right region -->
        <path d="M 175,115 L 205,115 L 205,160 L 175,160 L 175,195 L 210,195 L 210,140 L 185,140 L 185,210" 
              stroke="#ffd700" stroke-width="2" fill="none" class="circuit-trace" style="--duration: 3.4s; --delay: 1.5s;" />
        
        <!-- Bottom-left region -->
        <path d="M 18,240 L 48,240 L 48,280 L 25,280 L 25,320 L 60,320 L 60,265 L 35,265 L 35,305" 
              stroke="#ffd700" stroke-width="2" fill="none" class="circuit-trace" style="--duration: 3.0s; --delay: 1.8s;" />
        
        <!-- Bottom-center region -->
        <path d="M 105,245 L 105,305 L 70,305 L 70,340 L 130,340 L 130,280 L 95,280 L 95,325" 
              stroke="#ffd700" stroke-width="2" fill="none" class="circuit-trace" style="--duration: 3.6s; --delay: 2.1s;" />
        
        <!-- Bottom-right region -->
        <path d="M 180,250 L 210,250 L 210,305 L 170,305 L 170,335 L 205,335 L 205,275 L 185,275 L 185,345" 
              stroke="#ffd700" stroke-width="2" fill="none" class="circuit-trace" style="--duration: 2.9s; --delay: 2.4s;" />
        
        <!-- Diagonal cross-connects (45° angles) -->
        <path d="M 40,22 L 68,50 L 68,95" 
              stroke="#ffd700" stroke-width="1.5" fill="none" class="circuit-trace" style="--duration: 2.7s; --delay: 0.4s;" />
        
        <path d="M 175,30 L 145,60 L 145,110" 
              stroke="#ffd700" stroke-width="1.5" fill="none" class="circuit-trace" style="--duration: 2.6s; --delay: 0.8s;" />
        
        <path d="M 30,150 L 65,120 L 110,120" 
              stroke="#ffd700" stroke-width="1.5" fill="none" class="circuit-trace" style="--duration: 3.1s; --delay: 1.1s;" />
        
        <path d="M 190,170 L 155,140 L 110,140" 
              stroke="#ffd700" stroke-width="1.5" fill="none" class="circuit-trace" style="--duration: 3.3s; --delay: 1.4s;" />
        
        <path d="M 45,290 L 85,250 L 130,250" 
              stroke="#ffd700" stroke-width="1.5" fill="none" class="circuit-trace" style="--duration: 2.8s; --delay: 1.7s;" />
        
        <path d="M 185,310 L 145,270 L 95,270" 
              stroke="#ffd700" stroke-width="1.5" fill="none" class="circuit-trace" style="--duration: 3.2s; --delay: 2.0s;" />
      </svg>
      
      <div class="eye-container">
        <svg class="eye" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <radialGradient id="glow" cx="50%" cy="50%" r="50%">
            <stop offset="0%" stop-color="#d4a94a" stop-opacity="0.6" />
            <stop offset="60%" stop-color="#c89b3c" stop-opacity="0.2" />
            <stop offset="100%" stop-color="#000" stop-opacity="0" />
          </radialGradient>
          <filter id="blur">
            <feGaussianBlur stdDeviation="2" />
          </filter>
        </defs>
        <circle cx="100" cy="100" r="90" fill="url(#glow)" />
        <path d="M 20,100 Q 100,30 180,100 Q 100,170 20,100 Z"
              fill="none" stroke="#c89b3c" stroke-width="2" class="eye-outline" />
        <circle cx="100" cy="100" r="30" fill="none" stroke="#d4a94a" stroke-width="1.5" class="iris" />
        <circle cx="100" cy="100" r="12" fill="#d4a94a" class="pupil" />
        <circle cx="100" cy="100" r="4" fill="#ddb84d" filter="url(#blur)" class="inner-glow" />
        <line x1="20" y1="100" x2="180" y2="100" stroke="#c89b3c" stroke-width="0.5" opacity="0.4" />
      </svg>
      </div>
    </div>

    <h1>BROTHERBOX</h1>
    <p class="tagline">Eye See. Eye Learn. Eye Am Brotherbox.</p>
  </main>
</Layout>

<style>
  main {
    min-height: calc(100vh - 60px);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 2rem;
  }

  .eye-container {
    width: 180px;
    height: 180px;
    margin-bottom: 2rem;
  }

  .golden-frame {
    width: 200px;
    height: 320px;
    border: 6px solid #d4a94a;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 2rem;
    box-shadow: 
      0 0 20px rgba(212, 169, 74, 0.3),
      inset 0 0 10px rgba(212, 169, 74, 0.1);
    position: relative;
  }

  .kirby-circuits {
    position: absolute;
    width: 100%;
    height: 100%;
    top: 0;
    left: 0;
    pointer-events: none;
    clip-path: polygon(
      0% 0%, 100% 0%, 100% 100%, 0% 100%, 0% 0%,
      35% 25%, 35% 75%, 65% 75%, 65% 25%, 35% 25%
    );
  }

  .circuit-line {
    animation: circuit-flow 3s ease-in-out infinite;
    filter: drop-shadow(0 0 3px rgba(212, 169, 74, 0.6));
  }

  .circuit-line.circuit-pulse {
    animation: circuit-pulse-flow 4s ease-in-out infinite;
  }

  .circuit-node {
    animation: node-glow 2s ease-in-out infinite;
    filter: drop-shadow(0 0 4px rgba(255, 215, 0, 0.8));
  }

  .circuit-trace {
    stroke-dasharray: 1000;
    stroke-dashoffset: 1000;
    filter: drop-shadow(0 0 2px rgba(255, 215, 0, 0.8));
    animation: trace-draw var(--duration, 3s) ease-in-out var(--delay, 0s) forwards;
  }

  @keyframes trace-draw {
    0% {
      stroke-dashoffset: 1000;
      stroke-opacity: 0.2;
    }
    20% {
      stroke-opacity: 1;
    }
    80% {
      stroke-opacity: 1;
    }
    100% {
      stroke-dashoffset: 0;
      stroke-opacity: 0.4;
    }
  }

  @keyframes circuit-flow {
    0% {
      stroke-opacity: 0.4;
      filter: drop-shadow(0 0 2px rgba(212, 169, 74, 0.3));
    }
    50% {
      stroke-opacity: 1;
      filter: drop-shadow(0 0 6px rgba(255, 215, 0, 0.9));
    }
    100% {
      stroke-opacity: 0.4;
      filter: drop-shadow(0 0 2px rgba(212, 169, 74, 0.3));
    }
  }

  @keyframes circuit-pulse-flow {
    0%, 100% {
      stroke-opacity: 0.3;
      filter: drop-shadow(0 0 1px rgba(212, 169, 74, 0.2));
    }
    25% {
      stroke-opacity: 0.7;
      filter: drop-shadow(0 0 4px rgba(212, 169, 74, 0.5));
    }
    50% {
      stroke-opacity: 1;
      filter: drop-shadow(0 0 8px rgba(255, 215, 0, 1));
    }
    75% {
      stroke-opacity: 0.7;
      filter: drop-shadow(0 0 4px rgba(212, 169, 74, 0.5));
    }
  }

  @keyframes node-glow {
    0%, 100% {
      r: 2.5;
      opacity: 0.6;
    }
    50% {
      r: 3.5;
      opacity: 1;
    }
  }

  .eye {
    width: 100%;
    height: 100%;
  }

  .eye-outline {
    animation: pulse-outline 4s ease-in-out infinite;
  }

  .iris {
    animation: pulse-iris 4s ease-in-out infinite;
  }

  .pupil {
    animation: pulse-pupil 3s ease-in-out infinite;
  }

  .inner-glow {
    animation: glow-pulse 2s ease-in-out infinite;
  }

  @keyframes pulse-outline {
    0%, 100% { stroke-opacity: 0.6; }
    50% { stroke-opacity: 1; }
  }

  @keyframes pulse-iris {
    0%, 100% { r: 30; stroke-opacity: 0.7; }
    50% { r: 32; stroke-opacity: 1; }
  }

  @keyframes pulse-pupil {
    0%, 100% { r: 12; fill-opacity: 0.8; }
    50% { r: 14; fill-opacity: 1; }
  }

  @keyframes glow-pulse {
    0%, 100% { r: 4; opacity: 0.6; }
    50% { r: 6; opacity: 1; }
  }

  h1 {
    font-size: 2rem;
    letter-spacing: 0.5em;
    color: #c89b3c;
    margin-bottom: 0.5rem;
  }

  .tagline {
    color: #666;
    font-size: 0.9rem;
    letter-spacing: 0.15em;
    margin-bottom: 2rem;
  }

  @media (max-width: 600px) {
    h1 {
      font-size: 1.5rem;
    }
  }
</style>

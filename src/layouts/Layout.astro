---
import Nav from '../components/Nav.astro';

interface Props {
  title: string;
  fullscreen?: boolean;
}

const { title, fullscreen = false } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — BrotherBox</title>
    <style is:global>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      body {
        font-family: 'Courier New', monospace;
        background: #000;
        color: #ccc;
      }
    </style>
  </head>
  <body>
    {!fullscreen && <Nav />}
    <slot />
  </body>
</html>

---
import Layout from '../layouts/Layout.astro';
---

<Layout title="BrotherBox">
  <main>
    <div class="golden-frame">
      <svg class="kirby-circuits" viewBox="0 0 220 360" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <linearGradient id="circuit-glow" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" stop-color="#d4a94a" stop-opacity="0.8" />
            <stop offset="50%" stop-color="#ffd700" stop-opacity="1" />
            <stop offset="100%" stop-color="#c89b3c" stop-opacity="0.8" />
          </linearGradient>
        </defs>
        
        <!-- Top-left network -->
        <path d="M 8,8 L 45,8 L 45,28 L 18,28 L 18,52 L 52,52 L 52,72 L 28,72 L 28,95" 
              stroke="url(#circuit-glow)" stroke-width="3" fill="none" stroke-linecap="square" class="circuit-line" />
        
        <!-- Top-right network -->
        <path d="M 212,12 L 175,12 L 175,35 L 195,35 L 195,58 L 165,58 L 165,82 L 188,82 L 188,108" 
              stroke="url(#circuit-glow)" stroke-width="3" fill="none" stroke-linecap="square" class="circuit-line" />
        
        <!-- Left-middle vertical -->
        <path d="M 12,110 L 12,145 L 38,145 L 38,165 L 15,165 L 15,195 L 42,195 L 42,225" 
              stroke="url(#circuit-glow)" stroke-width="3" fill="none" stroke-linecap="square" class="circuit-line" />
        
        <!-- Right-middle vertical -->
        <path d="M 208,115 L 208,150 L 180,150 L 180,172 L 205,172 L 205,198 L 178,198 L 178,230" 
              stroke="url(#circuit-glow)" stroke-width="3" fill="none" stroke-linecap="square" class="circuit-line" />
        
        <!-- Center-left diagonal network -->
        <path d="M 35,115 L 68,115 L 68,140 L 45,140 L 45,165 L 72,165 L 72,188 L 50,188 L 50,215" 
              stroke="url(#circuit-glow)" stroke-width="2.5" fill="none" stroke-linecap="square" class="circuit-line circuit-pulse" />
        
        <!-- Center-right diagonal network -->
        <path d="M 185,120 L 152,120 L 152,145 L 175,145 L 175,168 L 148,168 L 148,192 L 170,192 L 170,218" 
              stroke="url(#circuit-glow)" stroke-width="2.5" fill="none" stroke-linecap="square" class="circuit-line circuit-pulse" />
        
        <!-- Bottom-left network -->
        <path d="M 18,245 L 18,280 L 48,280 L 48,305 L 25,305 L 25,340 L 58,340 L 58,352" 
              stroke="url(#circuit-glow)" stroke-width="3" fill="none" stroke-linecap="square" class="circuit-line" />
        
        <!-- Bottom-right network -->
        <path d="M 202,250 L 202,285 L 172,285 L 172,310 L 195,310 L 195,345 L 162,345 L 162,352" 
              stroke="url(#circuit-glow)" stroke-width="3" fill="none" stroke-linecap="square" class="circuit-line" />
        
        <!-- Center cross network -->
        <path d="M 75,95 L 95,95 L 95,125 L 125,125 L 125,100 L 145,100 L 145,140 L 110,140 L 110,175 L 130,175 L 130,210 L 90,210 L 90,245" 
              stroke="url(#circuit-glow)" stroke-width="2" fill="none" stroke-linecap="square" class="circuit-line" />
        
        <!-- Diagonal 45-degree network (top-left to bottom-right) -->
        <path d="M 28,35 L 42,49 L 55,49 L 55,75 L 68,75 L 68,95 L 82,109 L 82,135 L 105,135 L 105,155 L 125,155 L 125,175 L 145,175 L 145,195 L 165,195 L 165,220 L 185,220 L 185,245" 
              stroke="url(#circuit-glow)" stroke-width="2" fill="none" stroke-linecap="square" class="circuit-line circuit-pulse" />
        
        <!-- Diagonal 45-degree network (top-right to bottom-left) -->
        <path d="M 192,18 L 178,32 L 165,32 L 165,58 L 152,58 L 152,78 L 138,92 L 138,118 L 115,118 L 115,138 L 95,138 L 95,158 L 75,158 L 75,178 L 55,178 L 55,203 L 35,203 L 35,228" 
              stroke="url(#circuit-glow)" stroke-width="2" fill="none" stroke-linecap="square" class="circuit-line circuit-pulse" />
        
        <!-- Scattered nodes -->
        <circle cx="45" cy="28" r="2" fill="#ffd700" class="circuit-node" />
        <circle cx="38" cy="145" r="2" fill="#d4a94a" class="circuit-node" />
        <circle cx="72" cy="165" r="2" fill="#ffd700" class="circuit-node" />
        <circle cx="152" cy="120" r="2" fill="#d4a94a" class="circuit-node" />
        <circle cx="125" cy="155" r="2" fill="#ffd700" class="circuit-node" />
        <circle cx="48" cy="280" r="2" fill="#d4a94a" class="circuit-node" />
        <circle cx="172" cy="285" r="2" fill="#ffd700" class="circuit-node" />
        <circle cx="110" cy="175" r="1.5" fill="#c89b3c" class="circuit-node" />
      </svg>
      
      <div class="eye-container">
        <svg class="eye" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <radialGradient id="glow" cx="50%" cy="50%" r="50%">
            <stop offset="0%" stop-color="#d4a94a" stop-opacity="0.6" />
            <stop offset="60%" stop-color="#c89b3c" stop-opacity="0.2" />
            <stop offset="100%" stop-color="#000" stop-opacity="0" />
          </radialGradient>
          <filter id="blur">
            <feGaussianBlur stdDeviation="2" />
          </filter>
        </defs>
        <circle cx="100" cy="100" r="90" fill="url(#glow)" />
        <path d="M 20,100 Q 100,30 180,100 Q 100,170 20,100 Z"
              fill="none" stroke="#c89b3c" stroke-width="2" class="eye-outline" />
        <circle cx="100" cy="100" r="30" fill="none" stroke="#d4a94a" stroke-width="1.5" class="iris" />
        <circle cx="100" cy="100" r="12" fill="#d4a94a" class="pupil" />
        <circle cx="100" cy="100" r="4" fill="#ddb84d" filter="url(#blur)" class="inner-glow" />
        <line x1="20" y1="100" x2="180" y2="100" stroke="#c89b3c" stroke-width="0.5" opacity="0.4" />
      </svg>
      </div>
    </div>

    <h1>BROTHERBOX</h1>
    <p class="tagline">Eye See. Eye Learn. Eye Am Brotherbox.</p>
  </main>
</Layout>

<style>
  main {
    min-height: calc(100vh - 60px);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 2rem;
  }

  .eye-container {
    width: 180px;
    height: 180px;
    margin-bottom: 2rem;
  }

  .golden-frame {
    width: 200px;
    height: 320px;
    border: 6px solid #d4a94a;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 2rem;
    box-shadow: 
      0 0 20px rgba(212, 169, 74, 0.3),
      inset 0 0 10px rgba(212, 169, 74, 0.1);
    position: relative;
  }

  .kirby-circuits {
    position: absolute;
    width: 100%;
    height: 100%;
    top: 0;
    left: 0;
    pointer-events: none;
  }

  .circuit-line {
    animation: circuit-flow 3s ease-in-out infinite;
    filter: drop-shadow(0 0 3px rgba(212, 169, 74, 0.6));
  }

  .circuit-line.circuit-pulse {
    animation: circuit-pulse-flow 4s ease-in-out infinite;
  }

  .circuit-node {
    animation: node-glow 2s ease-in-out infinite;
    filter: drop-shadow(0 0 4px rgba(255, 215, 0, 0.8));
  }

  @keyframes circuit-flow {
    0% {
      stroke-opacity: 0.4;
      filter: drop-shadow(0 0 2px rgba(212, 169, 74, 0.3));
    }
    50% {
      stroke-opacity: 1;
      filter: drop-shadow(0 0 6px rgba(255, 215, 0, 0.9));
    }
    100% {
      stroke-opacity: 0.4;
      filter: drop-shadow(0 0 2px rgba(212, 169, 74, 0.3));
    }
  }

  @keyframes circuit-pulse-flow {
    0%, 100% {
      stroke-opacity: 0.3;
      filter: drop-shadow(0 0 1px rgba(212, 169, 74, 0.2));
    }
    25% {
      stroke-opacity: 0.7;
      filter: drop-shadow(0 0 4px rgba(212, 169, 74, 0.5));
    }
    50% {
      stroke-opacity: 1;
      filter: drop-shadow(0 0 8px rgba(255, 215, 0, 1));
    }
    75% {
      stroke-opacity: 0.7;
      filter: drop-shadow(0 0 4px rgba(212, 169, 74, 0.5));
    }
  }

  @keyframes node-glow {
    0%, 100% {
      r: 2.5;
      opacity: 0.6;
    }
    50% {
      r: 3.5;
      opacity: 1;
    }
  }

  .eye {
    width: 100%;
    height: 100%;
  }

  .eye-outline {
    animation: pulse-outline 4s ease-in-out infinite;
  }

  .iris {
    animation: pulse-iris 4s ease-in-out infinite;
  }

  .pupil {
    animation: pulse-pupil 3s ease-in-out infinite;
  }

  .inner-glow {
    animation: glow-pulse 2s ease-in-out infinite;
  }

  @keyframes pulse-outline {
    0%, 100% { stroke-opacity: 0.6; }
    50% { stroke-opacity: 1; }
  }

  @keyframes pulse-iris {
    0%, 100% { r: 30; stroke-opacity: 0.7; }
    50% { r: 32; stroke-opacity: 1; }
  }

  @keyframes pulse-pupil {
    0%, 100% { r: 12; fill-opacity: 0.8; }
    50% { r: 14; fill-opacity: 1; }
  }

  @keyframes glow-pulse {
    0%, 100% { r: 4; opacity: 0.6; }
    50% { r: 6; opacity: 1; }
  }

  h1 {
    font-size: 2rem;
    letter-spacing: 0.5em;
    color: #c89b3c;
    margin-bottom: 0.5rem;
  }

  .tagline {
    color: #666;
    font-size: 0.9rem;
    letter-spacing: 0.15em;
    margin-bottom: 2rem;
  }

  @media (max-width: 600px) {
    h1 {
      font-size: 1.5rem;
    }
  }
</style>

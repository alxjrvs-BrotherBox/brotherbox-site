<style>
  main {
    min-height: 100vh;
    max-width: 700px;
    margin: 0 auto;
    padding: 3rem 2rem;
    font-family: 'Courier New', monospace;
  }

  h1 {
    font-size: 1.5rem;
    color: #c89b3c;
    letter-spacing: 0.3em;
    margin-bottom: 0.5rem;
  }

  .subtitle {
    color: #555;
    font-size: 0.8rem;
    margin-bottom: 2rem;
  }

  .log {
    border-top: 1px solid #222;
  }

  .empty-state {
    color: #444;
    font-style: italic;
    padding: 2rem 0;
    text-align: center;
  }

  :global(.log-entry) {
    display: flex;
    gap: 1rem;
    padding: 0.75rem 0;
    border-bottom: 1px solid #111;
    font-size: 0.8rem;
    align-items: baseline;
  }

  :global(.log-ts) {
    color: #555;
    white-space: nowrap;
    flex-shrink: 0;
  }

  :global(.log-status) {
    font-weight: bold;
    white-space: nowrap;
    flex-shrink: 0;
  }

  :global(.log-status.healthy) {
    color: #22cc22;
  }

  :global(.log-status.warning) {
    color: #ccaa00;
  }

  :global(.log-status.error) {
    color: #c89b3c;
  }

  :global(.log-msg) {
    color: #999;
  }
</style>

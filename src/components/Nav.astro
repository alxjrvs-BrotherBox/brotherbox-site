---
const currentPath = Astro.url.pathname;

const links = [
  { href: '/', label: 'Home' },
{ href: '/art/', label: 'Art' },
  { href: '/changelog/', label: 'Changelog' },
];
---

<nav class="site-nav">
  {links.map(link => (
    <a href={link.href} class:list={[{ active: currentPath === link.href }]}>{link.label}</a>
  ))}
</nav>

<style>
  .site-nav {
    display: flex;
    gap: 2rem;
    justify-content: center;
    padding: 1.5rem 2rem;
    font-family: 'Courier New', monospace;
    font-size: 0.8rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  .site-nav a {
    color: #555;
    text-decoration: none;
    transition: color 0.3s;
  }

  .site-nav a:hover {
    color: #c89b3c;
  }

  .site-nav a.active {
    color: #c89b3c;
  }
</style>
